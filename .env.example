# Copy this file to `.env` for local development convenience.
#
# These only take effect under `npm run dev`. Production builds strip ALL dev
# affordances regardless of these values (gated on Vite's import.meta.env.DEV).
# The runtime path (no uploads, no AI, no telemetry) is unchanged.

# Auto-load a synthetic sample document and show the dev FAB on boot.
# Set to "false" to disable.
VITE_DEV_SAMPLE=true

# Path (served from /public) to the synthetic sample opened on boot.
VITE_DEV_SAMPLE_PATH=/dev-sample.md
